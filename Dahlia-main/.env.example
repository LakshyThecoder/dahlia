# Backend environment variables (required for FastAPI backend)
# Copy this file to backend/.env for local development, or set these values in the Vercel dashboard.

# MongoDB connection string (required)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/dahlia?retryWrites=true&w=majority

# MongoDB database name (required)
DB_NAME=dahlia

# Allowed CORS origins, comma-separated (optional, defaults to '*')
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Frontend environment variables (used by React)
# Set these in the Vercel dashboard for the frontend project.

# URL of the deployed backend API
REACT_APP_API_URL=https://your-backend.vercel.app/api

# Mistral API key for Dahlia AI chat feature
REACT_APP_MISTRAL_API_KEY=your_mistral_api_key_here
